{
  "manifest_version": 3,
  "name": "ChatGPT Approval Helper",
  "version": "0.3.1",
  "description": "Highlight trusted ChatGPT approval dialogs and auto-approve MCP tools, MCP servers, and connectors based on your allowlists.",
  "permissions": ["storage"],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": [
        "shared/defaults.js",
        "shared/storage.js",
        "shared/dom.js",
        "shared/clicker.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
